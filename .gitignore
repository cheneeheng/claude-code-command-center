# Secrets / local env — never commit
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Node / JS
node_modules/
*.vsix

# OS / editor cruft
.DS_Store
Thumbs.db

# file-sync: per-(file, pair) hidden launchers generated on install embed real local
# paths — keep them out of git (the committed hidden.vbs template stays tracked).
tools/file-sync/file-sync-*-hidden.vbs
